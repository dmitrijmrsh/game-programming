{"ts":"2026-04-07T12:33:48.619Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":1302,"action":"execute","params":{"action":"execute","code":"var names = new[] { \"Current_Z2\", \"Current_Z3\", \"Current_Jet\", \"Current_Deep\" };\nvar sb = new System.Text.StringBuilder();\nforeach (var name in names)\n{\n    var zone = GameObject.Find(name)?.GetComponent<CurrentZone>();\n    if (zone == null)\n    {\n        sb.AppendLine($\"{name}: missing\");\n        continue;\n    }\n\n    var center = zone.GetWorldCenter();\n    var neutral = zone.GetForceAt(center, false, false).magnitude;\n    var speeder = zone.GetForceAt(center, true, false).magnitude;\n    var armorer = zone.GetForceAt(center, false, true).magnitude;\n    sb.AppendLine($\"{name}: neutral={neutral:F2} speeder={speeder:F2} armorer={armorer:F2} tint={zone.GetCurrentTint()}\");\n}\nreturn sb.ToString();","safety_checks":true,"compiler":"auto"}}
