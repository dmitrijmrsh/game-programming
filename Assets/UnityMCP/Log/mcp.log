{"ts":"2026-04-07T13:33:52.878Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":1748,"action":"execute","params":{"action":"execute","code":"var player = UnityEngine.Object.FindAnyObjectByType<BathyscapheController>();\nvar rb = player != null ? player.GetComponent<Rigidbody>() : null;\nvar beam = UnityEngine.Object.FindAnyObjectByType<LightBeam>();\nvar manager = UnityEngine.Object.FindAnyObjectByType<FlockingManager>();\nvar zones = UnityEngine.Object.FindObjectsByType<CurrentZone>();\nif (player == null || beam == null || rb == null) return \"missing\";\n\nvar setBeamActive = typeof(LightBeam).GetMethod(\"SetBeamActive\", System.Reflection.BindingFlags.Instance | System.Reflection.BindingFlags.NonPublic);\nsetBeamActive.Invoke(beam, new object[]{ true });\n\nvar jet = zones.FirstOrDefault(z => z.name == \"Current_Jet\");\nif (jet != null)\n{\n    player.transform.position = jet.GetWorldCenter();\n    rb.linearVelocity = Vector3.zero;\n}\n\nvar agents = UnityEngine.Object.FindObjectsByType<FlockingAgent>()\n    .OrderBy(a => Vector3.Distance(player.transform.position, a.transform.position))\n    .Take(3)\n    .ToArray();\nfor (int i = 0; i < agents.Length; i++)\n{\n    agents[i].transform.position = beam.transform.position + beam.transform.forward * (8f + i * 2f) + beam.transform.right * (i - 1) * 1.5f;\n    agents[i].Velocity = Vector3.zero;\n}\n\nfor (int step = 0; step < 60; step++)\n{\n    manager.SendMessage(\"Update\");\n    rb.AddForce(CurrentField.Instance.SampleCurrent(player.transform.position, Time.time) * 6f, ForceMode.Force);\n}\n\nvar beamParticles = typeof(LightBeam).GetField(\"beamParticles\", System.Reflection.BindingFlags.Instance | System.Reflection.BindingFlags.NonPublic)?.GetValue(beam) as ParticleSystem;\nvar beamLine = typeof(LightBeam).GetField(\"beamLine\", System.Reflection.BindingFlags.Instance | System.Reflection.BindingFlags.NonPublic)?.GetValue(beam) as LineRenderer;\nreturn new {\n    playerPos = player.transform.position,\n    following = manager.CountFollowing(),\n    beamActive = beam.IsActive,\n    beamParticlesPlaying = beamParticles != null && beamParticles.isPlaying,\n    beamLineEnabled = beamLine != null && beamLine.enabled,\n    beamLineWidth = beamLine != null ? beamLine.startWidth : -1f,\n    currentMagnitude = CurrentField.Instance.SampleCurrent(player.transform.position, Time.time).magnitude,\n    rbVelocity = rb.linearVelocity.magnitude,\n    zoneForce = jet != null ? jet.GetForceAt(player.transform.position).magnitude : -1f\n};","safety_checks":true,"compiler":"auto"}}
