{"ts":"2026-04-07T09:35:11.967Z","tool":"manage_script","type":"tool","status":"SUCCESS","ms":73,"action":"edit","params":{"action":"edit","name":"BuoyancySystem","path":"Assets/DeepCanyon/Scripts/Bathyscaphe","namespace":null,"scriptType":"MonoBehaviour","edits":[{"op":"anchor_replace","anchor":"void FixedUpdate\\(\\)\\s*\\{[\\s\\S]*?\\n    \\}","text":"void FixedUpdate()\n    {\n        if (depthTracker == null) return;\n\n        float depth = Mathf.Abs(depthTracker.CurrentDepth);\n\n        // Never push the bathyscaphe upward when it is already above the water surface.\n        if (depth <= 0.01f)\n        {\n            if (rb.linearVelocity.y > 0f)\n            {\n                Vector3 velocity = rb.linearVelocity;\n                velocity.y *= 0.85f;\n                rb.linearVelocity = velocity;\n            }\n            return;\n        }\n\n        float force = buoyancyForce * Mathf.Exp(-depth * buoyancyFalloff);\n        rb.AddForce(Vector3.up * force, ForceMode.Force);\n    }"}],"options":{"validate":"standard","refresh":"immediate"}}}
