{"ts":"2026-04-07T11:18:06.873Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":1136,"action":"execute","params":{"action":"execute","code":"var player = UnityEngine.GameObject.Find(\"Bathyscaphe\");\nif (player == null) return new { found = false };\nvar depth = player.GetComponent<DepthTracker>();\nvar hull = player.GetComponent<HullIntegrity>();\nvar leaks = player.GetComponentsInChildren<UnityEngine.ParticleSystem>(true)\n    .Where(ps => ps.name.StartsWith(\"Leak_\"))\n    .Select(ps => new {\n        ps.name,\n        isPlaying = ps.isPlaying,\n        rate = ps.emission.rateOverTime.constant,\n        speed = ps.main.startSpeed.constant,\n        size = ps.main.startSize.constant\n    }).ToArray();\nreturn new {\n    found = true,\n    position = player.transform.position,\n    depth = depth != null ? depth.CurrentDepth : 0f,\n    normalizedPressure = depth != null ? depth.NormalizedPressure : 0f,\n    hull = hull != null ? hull.CurrentHull : 0f,\n    hullPercent = hull != null ? hull.HullPercent : 0f,\n    leaks\n};","safety_checks":true,"compiler":"auto"}}
